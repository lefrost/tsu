		"typescript-eslint": "^8.65.0",
		"vaul-svelte": "^0.3.2",
		"vite": "^8.1.5",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@tsu/all": "workspace:*",
		"mode-watcher": "^1.1.0"
	}
