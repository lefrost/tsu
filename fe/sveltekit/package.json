		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.22.0",
		"formsnap": "^2.0.1",
		"globals": "^17.7.0",
		"layerchart": "2.0.2",
		"paneforge": "^1.0.2",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.1",
		"shadcn-svelte": "^1.4.2",
		"svelte": "^5.56.7",
		"svelte-adapter-bun": "^1.0.1",
