{
  "name": "@tsu/all",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "db:push": "bun run --env-file=../.env drizzle-kit push",
    "db:generate": "bun run --env-file=../.env drizzle-kit generate",
    "db:migrate": "bun run --env-file=../.env drizzle-kit migrate",
    "db:studio": "bun run --env-file=../.env drizzle-kit studio",
    "auth:schema": "bun run --env-file=../.env better-auth generate --config ./src/auth.ts --output ./src/auth.schema.ts --yes"
  },
  "dependencies": {
		"@better-auth/cli": "latest",
    "drizzle-orm": "^0.45.2",
    "@neondatabase/serverless": "^1.1.0",
    "better-auth": "~1.4.21"
  },
  "devDependencies": {
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}