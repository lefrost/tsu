{
  "name": "@tsu/all",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "db:push": "drizzle-kit --config=./drizzle/drizzle.config.ts push",
    "db:generate": "drizzle-kit --config=./drizzle/drizzle.config.ts generate",
    "db:migrate": "drizzle-kit --config=./drizzle/drizzle.config.ts migrate",
    "db:studio": " drizzle-kit --config=./drizzle/drizzle.config.ts studio",
    "auth:schema": "better-auth generate --config ./betterauth/auth.ts --output ./betterauth/schema.ts --yes"
  },
  "dependencies": {
    "@better-auth/cli": "latest",
    "@neondatabase/serverless": "^1.1.0",
    "better-auth": "~1.4.21",
    "drizzle-orm": "^0.45.2",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.22.0",
    "@types/nodemailer": "^8.0.1",
    "bun-types": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}