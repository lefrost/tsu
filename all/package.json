{
  "name": "@tsu/all",
  "version": "0.0.1",
  "private": true,
  "exports": {
    "./betterauth": "./fe/betterauth/instance.ts",
    "./betterauth/schema": "./fe/betterauth/schema.ts",
    "./drizzle": "./fe/drizzle/instance.ts",
    "./drizzle/schema": "./fe/drizzle/schema.ts",
    "./paraglide/*": "./fe/paraglide/generated/*"
  },
  "typesVersions": {
    "*": {
      "betterauth": [
        "./fe/betterauth/instance.ts"
      ],
      "betterauth/schema": [
        "./fe/betterauth/schema.ts"
      ],
      "drizzle": [
        "./fe/drizzle/instance.ts"
      ],
      "drizzle/schema": [
        "./fe/drizzle/schema.ts"
      ],
      "paraglide/*": [
        "./fe/paraglide/generated/*"
      ]
    }
  },
  "scripts": {
    "db:reset": "bun run ./fe/drizzle/reset.ts",
    "db:push": "drizzle-kit --config=./fe/drizzle/drizzle.config.ts push --force",
    "db:generate": "drizzle-kit --config=./fe/drizzle/drizzle.config.ts generate",
    "db:migrate": "drizzle-kit --config=./fe/drizzle/drizzle.config.ts migrate",
    "db:studio": "drizzle-kit --config=./fe/drizzle/drizzle.config.ts studio",
    "auth:schema": "better-auth generate --config ./fe/betterauth/instance.ts --output ./fe/betterauth/schema.ts --yes"
  },
  "dependencies": {
    "@better-auth/cli": "^1.4.21",
    "@better-auth/i18n": "^1.6.25",
    "@neondatabase/serverless": "^1.1.0",
    "better-auth": "^1.6.23",
    "better-call": "^2.0.5",
    "drizzle-orm": "^0.45.2",
    "nodemailer": "^9.0.3"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.22.0",
    "@types/nodemailer": "^8.0.1",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "typescript": "^7.0.2"
  }
}